{
  "private": true,
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "dev:react": "npm run dev --prefix electron/renderer -- --port 5176",
    "dev:electron": "wait-on http://localhost:5176 && electron .",
    "dev": "concurrently \"npm run dev:react\" \"npm run dev:electron\"",
    "build": "vite build"
  },
  "devDependencies": {
    "axios": "^1.15.0",
    "laravel-vite-plugin": "^1.0.0",
    "vite": "^5.0.0"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.103.3",
    "concurrently": "^9.2.1",
    "electron": "^41.2.1",
    "form-data": "^4.0.5",
    "screenshot-desktop": "^1.15.3",
    "wait-on": "^9.0.5"
  }
}
