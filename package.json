{
  

  "devDependencies": {
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "autoprefixer": "^10.5.0",
    "axios": "^1.15.0",
    "electron": "^41.2.1",
    "electron-builder": "^24.13.3",
    "laravel-vite-plugin": "^1.0.0",
    "postcss": "^8.5.14",
    "tailwindcss": "^3.4.17",
    "vite": "^5.0.0"
  },

  "dependencies": {
    "@supabase/supabase-js": "^2.103.3",
    "active-win": "^8.2.1",
    "concurrently": "^9.2.1",
    "form-data": "^4.0.5",
    "lucide-react": "^1.8.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "screenshot-desktop": "^1.15.3",
    "wait-on": "^9.0.5"
  },

  "build": {
  "appId": "com.worksnap.app",
  "productName": "WorkSnap",

  "directories": {
    "output": "dist"
  },

  "files": [
    "**/*",
    "!electron/renderer/node_modules/**/*"
  ],

  "asar": true,

  "asarUnpack": [
    "**/node_modules/active-win/**/*",
    "**/node_modules/screenshot-desktop/**/*"
  ],

  "win": {
    "target": [
      {
        "target": "nsis",
        "arch": ["x64"]
      }
    ],
    "requestedExecutionLevel": "requireAdministrator"
  },

  "nsis": {
    "oneClick": false,
    "allowToChangeInstallationDirectory": true,
    "createDesktopShortcut": true,
    "createStartMenuShortcut": true,
    "runAfterFinish": true
  }
}
}