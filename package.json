    "vite": "^5.0.0"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.103.3",
    "active-win": "^8.2.1",
    "concurrently": "^9.2.1",
    "electron": "^41.2.1",
    "form-data": "^4.0.5",
    "lucide-react": "^1.8.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
